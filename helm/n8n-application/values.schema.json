{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "n8n-application Helm Values",
  "description": "Schema for n8n-application Helm chart values",
  "type": "object",
  "required": ["replicaCount", "image", "n8n", "database"],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of n8n replicas"
    },
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "repository": {
          "type": "string",
          "description": "n8n container image repository"
        },
        "tag": {
          "type": "string",
          "description": "n8n container image tag"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "additionalProperties": false
    },
    "n8n": {
      "type": "object",
      "required": ["port", "protocol"],
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "default": 5678
        },
        "protocol": {
          "type": "string",
          "enum": ["http", "https"]
        },
        "executionDataMaxAge": {
          "type": "string"
        },
        "executionDataPruneMaxCount": {
          "type": "string"
        },
        "logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"]
        },
        "logOutput": {
          "type": "string"
        },
        "webhookUrl": {
          "type": "string"
        }
      }
    },
    "database": {
      "type": "object",
      "required": ["type", "host", "port", "database"],
      "properties": {
        "type": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "database": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "ssl": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "postgres": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string"
            },
            "tag": {
              "type": "string"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "resources": {
          "type": "object"
        },
        "persistence": {
          "type": "object",
          "properties": {
            "storageClass": {
              "type": "string"
            },
            "size": {
              "type": "string"
            }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "image": {
              "type": "object"
            },
            "resources": {
              "type": "object"
            }
          }
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "refreshInterval": {
          "type": "string"
        },
        "vault": {
          "type": "object"
        }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "scrapeInterval": {
          "type": "string"
        },
        "scrapeTimeout": {
          "type": "string"
        },
        "additionalLabels": {
          "type": "object"
        },
        "grafanaDashboard": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "namespace": {
              "type": "string"
            }
          }
        }
      }
    },
    "backup": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "schedule": {
          "type": "string"
        },
        "retention": {
          "type": "integer",
          "minimum": 1
        },
        "storageSize": {
          "type": "string"
        },
        "offCluster": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string" },
            "bucket": { "type": "string" },
            "path": { "type": "string" },
            "credentialsSecret": { "type": "string" },
            "rclone": {
              "type": "object",
              "properties": {
                "image": {
                  "type": "object",
                  "properties": {
                    "repository": { "type": "string" },
                    "tag": { "type": "string" }
                  }
                },
                "resources": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "queue": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "redis": {
          "type": "object",
          "properties": {
            "image": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "redisResources": { "type": "object" },
        "worker": {
          "type": "object",
          "properties": {
            "replicas": { "type": "integer", "minimum": 1 },
            "healthPort": { "type": "integer" },
            "resources": { "type": "object" }
          }
        }
      }
    },
    "resourceQuota": {
      "type": "object",
      "required": ["requests", "limits", "pods", "pvcs"],
      "properties": {
        "requests": {
          "type": "object",
          "required": ["cpu", "memory"],
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "required": ["cpu", "memory"],
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "pods": { "type": "string" },
        "pvcs": { "type": "string" }
      }
    },
    "initContainers": {
      "type": "object",
      "properties": {
        "busybox": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "allowedNamespaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "hosts": {
          "type": "array"
        },
        "tls": {
          "type": "array"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        }
      }
    },
    "namespace": {
      "type": "string"
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "serviceAccount": {
      "type": "object"
    },
    "podAnnotations": {
      "type": "object"
    },
    "podSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    },
    "service": {
      "type": "object"
    },
    "persistence": {
      "type": "object"
    },
    "autoscaling": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    },
    "extraEnv": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "valueFrom": { "type": "object" }
        }
      }
    }
  }
}
